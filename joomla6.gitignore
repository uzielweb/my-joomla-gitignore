# ==============================================================================
# EXTENSÕES DE TERCEIROS E CUSTOMIZAÇÕES
# ==============================================================================

# Se você tiver extensões de terceiros ou extensões customizadas,
# elas NÃO serão ignoradas porque não estão listadas acima.
#
# Exemplos do que SERÁ rastreado:
# - /templates/meu_template_customizado/
# - /plugins/system/minha_extensao/
# - /administrator/components/com_minha_extensao/
# - /language/pt-BR/ (idiomas adicionais)
# - /administrator/language/pt-BR/
# - /administrator/templates/atum/html/ (overrides do atum)
# - /templates/cassiopeia/html/ (overrides do cassiopeia)
#
# Se você quiser ignorar alguma extensão específica de terceiros, adicione aqui:
# /plugins/system/alguma_extensao_indesejada/

# ==============================================================================
# SCANS DE SEGURANÇA E ANÁLISES
# ==============================================================================

# Security Check Pro scans
/administrator/components/com_securitycheckpro/scans/*

# Web Analyze
/webanalyze/*

# Outros scans
/scans/*
/.scannerwork/

# ==============================================================================
# BACKUP E ARQUIVOS TEMPORÁRIOS
# ==============================================================================

# Backups do Akeeba
/administrator/components/com_akeeba/backup/*
/administrator/components/com_akeebabackup/backup/*
/backups/*

# Arquivos de atualização
/administrator/components/com_joomlaupdate/restore/*

# ==============================================================================
# FIM DO .gitignore
# ==============================================================================
