# ==============================================================================
# .gitignore para Joomla 3
# ==============================================================================
# Este arquivo ignora todos os arquivos padrão do Joomla 3 e permite rastrear
# apenas modificações em templates, idiomas e extensões de terceiros.
#
# Atualizado em: 16 de outubro de 2025
# ==============================================================================

# ==============================================================================
# ARQUIVOS DE SISTEMA E FERRAMENTAS DE DESENVOLVIMENTO
# ==============================================================================

# Arquivos de senha e segurança
.htpasswd
.env
.env.*

# Arquivos temporários do sistema
._*
*~
*.swp
*.swo
*.bak
*.tmp

# Node.js
node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock

# Compiled files
*.class
*.py[cod]
*.pyc
*.pyo
__pycache__/

# Log files
*.log
logs/
*.log.*

# Package files
*.jar

# Build artifacts
target/
dist/
build/

# IDEs, Editores e pastas personalizadas de desenvolvimento
.docs/
.github/
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
.project
.settings/
.buildpath
nbproject/

# Ferramentas de IA e Agentes
.copilot/
.cursor/
.cursorrules
.cursorignore
.cline/
cline_docs/
.roo/
.aider*
.agent/
.gemini/
.antigravity

# Unit test reports
TEST*.xml
coverage/
.phpunit.result.cache

# Sistema Operacional
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ==============================================================================
# ARQUIVOS GRANDES DE MÍDIA (opcional - descomente se necessário)
# ==============================================================================

# Vídeos
*.mp4
*.avi
*.flv
*.mov
*.wmv
*.mpg
*.mpeg
*.mkv
*.webm
*.ogg
*.ogv

# Áudio
*.mp3
*.wav
*.flac
*.m4a
*.aac

# Imagens grandes
*.tiff
*.psd

# Arquivos compactados
*.zip
*.rar
*.7z
*.gz
*.tar
*.tgz
*.bzip
*.bzip2
*.xz
*.lzma
*.cab
*.iso
*.tar.gz

# Executáveis
*.app
*.exe
*.war

